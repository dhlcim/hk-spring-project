<?xml version="1.0" encoding="UTF-8"?>

<!-- =====================================================
     beans_product.xml
     Spring Bean 의존관계 설정 파일
     서버 시작 시 Spring이 이 파일을 읽어 Bean을 생성하고 연결함
     ===================================================== -->

<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context"
    xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-4.3.xsd">

    <!-- ① db.properties 파일을 읽어옴
         classpath: → src/main/resources 폴더를 기준으로 파일을 찾음
         이 선언 덕분에 아래에서 ${db.xxx} 형태로 값을 꺼내 쓸 수 있음 -->
    <context:property-placeholder location="classpath:db.properties" />

    <!-- ② DataSource Bean 생성
         id: 이 Bean의 이름 (다른 곳에서 ref="dataSource"로 참조)
         class: Spring이 이 클래스로 객체를 new 해서 만들어 줌
         DB 연결 정보(드라이버, URL, 계정)를 담고 있는 부품 -->
    <bean id="dataSource" class="org.springframework.jdbc.datasource.DriverManagerDataSource">

        <!-- setDriverClassName() 호출 → MySQL JDBC 드라이버 클래스 등록 -->
        <property name="driverClassName" value="${db.driver.Class}" />

        <!-- setUrl() 호출 → 접속할 DB 주소 (IP, 포트, DB명) -->
        <property name="url" value="${db.url}" />

        <!-- setUsername() 호출 → DB 접속 계정 -->
        <property name="username" value="${db.username}" />

        <!-- setPassword() 호출 → DB 접속 비밀번호 -->
        <property name="password" value="${db.password}" />

    </bean>

    <!-- ③ ProductService Bean 생성
         id: 이 Bean의 이름 (Controller에서 @Autowired로 주입받음)
         class: Spring이 이 클래스로 객체를 new 해서 만들어 줌
         DB 조회 로직을 담당하는 핵심 부품 -->
    <bean id="productService" class="com.kopo.hkcode.product.ProductService">

        <!-- 생성자 첫 번째 파라미터: DataSource 주입
             ref → ②에서 만든 dataSource Bean을 그대로 넘겨줌
             ProductService(DataSource dataSource, ...) 생성자 호출됨 -->
        <constructor-arg ref="dataSource" />

        <!-- 생성자 두 번째 파라미터: List<String> 타입의 관리자 목록 주입
             ProductService(..., List<String> managerList) 생성자 호출됨 -->
        <constructor-arg>
            <list>
                <value>김대현 관리자</value>
                <value>전자정부 표준 관리자</value>
            </list>
        </constructor-arg>

    </bean>

</beans>